<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.cc-provider</string>
  <key>ProgramArguments</key>
  <array>
    <string>~/miniconda3/bin/python3</string>
    <string>-m</string>
    <string>uvicorn</string>
    <string>app:app</string>
    <string>--host</string>
    <string>0.0.0.0</string>
    <string>--port</string>
    <string>47290</string>
  </array>
  <key>WorkingDirectory</key>
  <string>~/dev/cc-provider</string>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>StandardOutPath</key>
  <string>~/.cc-provider/cc-provider.log</string>
  <key>StandardErrorPath</key>
  <string>~/.cc-provider/cc-provider.log</string>
</dict>
</plist>
